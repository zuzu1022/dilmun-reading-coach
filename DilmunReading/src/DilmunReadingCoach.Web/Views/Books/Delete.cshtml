@model Book
@{
    ViewData["Title"] = "Delete Book";
}

<h2>Delete Book</h2>
<hr />

<h3>Are you sure you want to deactivate this book?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">Title</dt>
        <dd class="col-sm-10">@Model.Title</dd>
        
        <dt class="col-sm-2">Author</dt>
        <dd class="col-sm-10">@Model.Author</dd>
        
        <dt class="col-sm-2">Category</dt>
        <dd class="col-sm-10">@Model.Category</dd>
        
        <dt class="col-sm-2">Reading Level</dt>
        <dd class="col-sm-10">@Model.ReadingLevel</dd>
    </dl>
    
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Deactivate</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>

