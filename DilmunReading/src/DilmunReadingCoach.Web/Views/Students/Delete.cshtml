@model Student
@{
    ViewData["Title"] = "Delete Student";
}

<h2>Delete Student</h2>
<hr />

<h3>Are you sure you want to deactivate this student?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">Student Code</dt>
        <dd class="col-sm-10">@Model.StudentCode</dd>
        
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.FirstName @Model.LastName</dd>
        
        <dt class="col-sm-2">Class</dt>
        <dd class="col-sm-10">@Model.Classroom?.Name</dd>
        
        <dt class="col-sm-2">Reading Level</dt>
        <dd class="col-sm-10">@Model.ReadingLevel</dd>
    </dl>
    
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Deactivate</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>

