@model List<PasswordResetRequest>
@using DilmunReadingCoach.Infrastructure.Identity
@{
    ViewData["Title"] = "Password Reset Requests";
    var users = ViewBag.Users as Dictionary<Guid, ApplicationUser> ?? new Dictionary<Guid, ApplicationUser>();
}

<div class="page-header">
    <h2><i class="bi bi-key me-2"></i>Password Reset Requests</h2>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
    </div>
}

<div class="card mb-4">
    <div class="card-body">
        <div class="btn-group" role="group">
            <a asp-action="Index" asp-route-status="" class="btn @(ViewBag.Status == null ? "btn-primary" : "btn-outline-primary")">
                <i class="bi bi-list-ul me-1"></i>All
            </a>
            <a asp-action="Index" asp-route-status="Pending" class="btn @(ViewBag.Status == "Pending" ? "btn-primary" : "btn-outline-warning")">
                <i class="bi bi-clock me-1"></i>Pending
            </a>
            <a asp-action="Index" asp-route-status="Approved" class="btn @(ViewBag.Status == "Approved" ? "btn-primary" : "btn-outline-success")">
                <i class="bi bi-check-circle me-1"></i>Approved
            </a>
            <a asp-action="Index" asp-route-status="Rejected" class="btn @(ViewBag.Status == "Rejected" ? "btn-primary" : "btn-outline-danger")">
                <i class="bi bi-x-circle me-1"></i>Rejected
            </a>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Requested Date</th>
                            <th>User</th>
                            <th>Status</th>
                            <th>Approved By</th>
                            <th>Approved Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var request in Model)
                        {
                            var user = users.ContainsKey(request.UserId) ? users[request.UserId] : null;
                            var approver = request.ApprovedBy.HasValue && users.ContainsKey(request.ApprovedBy.Value) 
                                ? users[request.ApprovedBy.Value] 
                                : null;

                            <tr>
                                <td><small>@request.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</small></td>
                                <td><strong>@(user?.UserName ?? request.UserId.ToString().Substring(0, 8))</strong></td>
                                <td>
                                    <span class="badge bg-@(request.Status == "Pending" ? "warning" : request.Status == "Approved" ? "success" : "danger")">
                                        @if (request.Status == "Pending")
                                        {
                                            <i class="bi bi-clock me-1"></i>
                                        }
                                        else if (request.Status == "Approved")
                                        {
                                            <i class="bi bi-check-circle me-1"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-x-circle me-1"></i>
                                        }
                                        @request.Status
                                    </span>
                                </td>
                                <td>@(approver?.UserName ?? "N/A")</td>
                                <td><small>@(request.ApprovedAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "N/A")</small></td>
                                <td>
                                    @if (request.Status == "Pending")
                                    {
                                        <button type="button" class="btn btn-sm btn-success me-1" onclick="showPasswordDialog('@request.Id', '@(user?.UserName ?? request.UserId.ToString().Substring(0, 8))')">
                                            <i class="bi bi-check me-1"></i>Approve
                                        </button>
                                        <form asp-action="Reject" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to reject this request?');">
                                            <input type="hidden" name="id" value="@request.Id" />
                                            <button type="submit" class="btn btn-sm btn-danger">
                                                <i class="bi bi-x me-1"></i>Reject
                                            </button>
                                        </form>
                                        
                                        <!-- Hidden form for submission -->
                                        <form asp-action="Approve" method="post" id="approveForm@(request.Id)" style="display:none;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@request.Id" />
                                            <input type="hidden" name="newPassword" id="hiddenPassword@(request.Id)" />
                                            <input type="hidden" name="confirmPassword" id="hiddenConfirmPassword@(request.Id)" />
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No actions available</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-state-icon"><i class="bi bi-inbox"></i></div>
                <p>No password reset requests found</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Polyfill for crypto.randomUUID if needed (for browser extensions)
        (function() {
            if (window.crypto && typeof window.crypto.randomUUID !== "function") {
                window.crypto.randomUUID = function () {
                    return "xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx".replace(/[xy]/g, function (c) {
                        const r = (window.crypto.getRandomValues
                            ? window.crypto.getRandomValues(new Uint8Array(1))[0] & 15
                            : Math.floor(Math.random() * 16)) | 0;
                        const v = c === "x" ? r : (r & 0x3) | 0x8;
                        return v.toString(16);
                    });
                };
            }
        })();

        // Modern password dialog
        function showPasswordDialog(requestId, username) {
            // Create overlay
            var overlay = document.createElement('div');
            overlay.id = 'passwordDialogOverlay';
            overlay.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);z-index:9998;display:flex;align-items:center;justify-content:center;';
            
            // Create dialog
            var dialog = document.createElement('div');
            dialog.style.cssText = 'background:white;border-radius:8px;padding:0;max-width:450px;width:90%;box-shadow:0 10px 40px rgba(0,0,0,0.2);z-index:9999;';
            dialog.innerHTML = `
                <div style="padding:24px;border-bottom:1px solid #e9ecef;">
                    <h5 style="margin:0;display:flex;align-items:center;gap:8px;">
                        <i class="bi bi-key" style="color:#0d6efd;"></i>
                        Set New Password
                    </h5>
                    <p style="margin:8px 0 0 0;color:#6c757d;font-size:14px;">Enter a new password for <strong>${username}</strong></p>
                </div>
                <div style="padding:24px;">
                    <div style="margin-bottom:16px;">
                        <label style="display:block;margin-bottom:6px;font-weight:500;font-size:14px;">
                            <i class="bi bi-lock" style="margin-right:4px;"></i>New Password
                        </label>
                        <input type="password" id="dialogPassword${requestId}" class="form-control" placeholder="Enter new password" style="width:100%;" />
                        <small style="color:#6c757d;font-size:12px;display:block;margin-top:4px;">Must be at least 6 characters with lowercase and digit</small>
                    </div>
                    <div style="margin-bottom:20px;">
                        <label style="display:block;margin-bottom:6px;font-weight:500;font-size:14px;">
                            <i class="bi bi-lock-fill" style="margin-right:4px;"></i>Confirm Password
                        </label>
                        <input type="password" id="dialogConfirmPassword${requestId}" class="form-control" placeholder="Confirm new password" style="width:100%;" />
                    </div>
                    <div style="display:flex;gap:8px;justify-content:flex-end;">
                        <button type="button" class="btn btn-secondary" onclick="closePasswordDialog('${requestId}')" style="min-width:80px;">Cancel</button>
                        <button type="button" class="btn btn-success" onclick="submitPasswordDialog('${requestId}')" style="min-width:150px;">
                            <i class="bi bi-check-circle me-1"></i>Approve & Set
                        </button>
                    </div>
                </div>
            `;
            
            overlay.appendChild(dialog);
            document.body.appendChild(overlay);
            
            // Focus on first input
            setTimeout(function() {
                var input = document.getElementById('dialogPassword' + requestId);
                if (input) input.focus();
            }, 100);
            
            // Close on overlay click
            overlay.addEventListener('click', function(e) {
                if (e.target === overlay) {
                    closePasswordDialog(requestId);
                }
            });
            
            // Close on Escape key
            var escapeHandler = function(e) {
                if (e.key === 'Escape') {
                    closePasswordDialog(requestId);
                    document.removeEventListener('keydown', escapeHandler);
                }
            };
            document.addEventListener('keydown', escapeHandler);
        }

        function closePasswordDialog(requestId) {
            var overlay = document.getElementById('passwordDialogOverlay');
            if (overlay) {
                overlay.remove();
            }
        }

        function submitPasswordDialog(requestId) {
            var password = document.getElementById('dialogPassword' + requestId).value;
            var confirmPassword = document.getElementById('dialogConfirmPassword' + requestId).value;
            
            // Validate
            if (!password || password.length < 6) {
                alert('Password must be at least 6 characters long.');
                return;
            }
            
            if (password !== confirmPassword) {
                alert('Passwords do not match. Please try again.');
                return;
            }
            
            // Set hidden form values and submit
            document.getElementById('hiddenPassword' + requestId).value = password;
            document.getElementById('hiddenConfirmPassword' + requestId).value = confirmPassword;
            
            // Close dialog
            closePasswordDialog(requestId);
            
            // Submit form
            var form = document.getElementById('approveForm' + requestId);
            if (form) {
                form.submit();
            }
        }
    </script>
}
