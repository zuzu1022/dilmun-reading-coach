@model List<Classroom>
@{
    ViewData["Title"] = "Classes";
}

<h2>Classes</h2>
<hr />

<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary">Add New Class</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Year Group</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var classroom in Model)
        {
            <tr>
                <td>@classroom.Name</td>
                <td>@classroom.YearGroup</td>
                <td>@classroom.Status</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@classroom.Id" class="btn btn-sm btn-primary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@classroom.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

