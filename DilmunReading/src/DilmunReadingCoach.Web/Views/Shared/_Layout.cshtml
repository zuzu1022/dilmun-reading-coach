<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Dilmun Reading Coach</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DilmunReadingCoach.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body>
    <div class="app-shell">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <aside class="sidebar" id="sidebar">
                <div class="sidebar-brand d-flex align-items-center mb-4">
                    <i class="bi bi-book-half me-2"></i>
                    <div>
                        <h5 class="mb-0">Dilmun</h5>
                        <small class="text-muted">Reading Coach</small>
                    </div>
                    <button class="sidebar-close d-lg-none ms-auto btn btn-link text-white" id="sidebarClose">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>

                <nav class="sidebar-nav flex-grow-1">
                    <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")"
                       asp-controller="Dashboard" asp-action="@(User.IsInRole("Coordinator") ? "Coordinator" : "Teacher")">
                        <i class="bi bi-speedometer2 me-3"></i> Dashboard
                    </a>

                    @if (User.IsInRole("Coordinator"))
                    {
                        <span class="sidebar-label">Management</span>
                        <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Students" ? "active" : "")"
                           asp-controller="Students" asp-action="Index">
                            <i class="bi bi-people me-3"></i> Students
                        </a>
                        <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Teachers" ? "active" : "")"
                           asp-controller="Teachers" asp-action="Index">
                            <i class="bi bi-person-badge me-3"></i> Teachers
                        </a>
                        <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Classes" ? "active" : "")"
                           asp-controller="Classes" asp-action="Index">
                            <i class="bi bi-building me-3"></i> Classes
                        </a>
                    }

                    <span class="sidebar-label">Reading</span>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Reading" ? "active" : "")"
                       asp-controller="Reading" asp-action="Index">
                        <i class="bi bi-journal-text me-3"></i> Records
                    </a>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Books" ? "active" : "")"
                       asp-controller="Books" asp-action="Index">
                        <i class="bi bi-book me-3"></i> Books
                    </a>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Reports" ? "active" : "")"
                       asp-controller="Reports" asp-action="Weekly">
                        <i class="bi bi-graph-up me-3"></i> Reports
                    </a>

                    @if (User.IsInRole("Coordinator"))
                    {
                        <span class="sidebar-label">Administration</span>
                        <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Backups" ? "active" : "")"
                           asp-controller="Backups" asp-action="Index">
                            <i class="bi bi-cloud-upload me-3"></i> Backups
                        </a>
                        <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "AuditLogs" ? "active" : "")"
                           asp-controller="AuditLogs" asp-action="Index">
                            <i class="bi bi-file-text me-3"></i> Audit Logs
                        </a>
                        <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "PasswordResets" ? "active" : "")"
                           asp-controller="PasswordResets" asp-action="Index">
                            <i class="bi bi-key me-3"></i> Password Resets
                        </a>
                    }
                </nav>

                <div class="sidebar-footer">
                    <div class="d-flex align-items-center">
                        <div class="avatar bg-primary text-white me-3">
                            @User.Identity.Name?.FirstOrDefault()
                        </div>
                        <div>
                            <strong>@User.Identity.Name</strong>
                            <div class="text-muted small">@string.Join(", ", User.Claims.Where(c => c.Type.Contains("role", StringComparison.OrdinalIgnoreCase)).Select(c => c.Value))</div>
                        </div>
                    </div>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="mt-3 w-100">
                        <button type="submit" class="btn btn-outline-light w-100">
                            <i class="bi bi-box-arrow-right me-2"></i>Logout
                        </button>
                    </form>
                </div>
            </aside>
        }

        <div class="app-content">
            <header class="topbar d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center gap-2">
                    <button class="btn btn-outline-secondary d-lg-none" id="sidebarToggle">
                        <i class="bi bi-list"></i>
                    </button>
                    <span class="text-muted">@ViewData["Title"]</span>
                </div>
                @if (User.Identity?.IsAuthenticated != true)
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-primary">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Login
                    </a>
                }
            </header>

            <main class="content-wrapper">
                @RenderBody()
            </main>
<!-- 
            <footer class="footer text-center">
                <p class="mb-0">&copy; 2024 Dilmun Reading Coach. All rights reserved.</p>
            </footer> -->
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/session-timeout.js" asp-append-version="true"></script>
    <script>
        (function () {
            const sidebar = document.getElementById('sidebar');
            const toggleBtn = document.getElementById('sidebarToggle');
            const closeBtn = document.getElementById('sidebarClose');

            if (toggleBtn && sidebar) {
                toggleBtn.addEventListener('click', () => {
                    sidebar.classList.toggle('sidebar-open');
                    document.body.classList.toggle('sidebar-open');
                });
            }

            if (closeBtn && sidebar) {
                closeBtn.addEventListener('click', () => {
                    sidebar.classList.remove('sidebar-open');
                    document.body.classList.remove('sidebar-open');
                });
            }
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
