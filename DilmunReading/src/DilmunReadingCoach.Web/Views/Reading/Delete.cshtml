@model ReadingProgress
@{
    ViewData["Title"] = "Delete Reading Record";
}

<h2>Delete Reading Record</h2>
<hr />

<h3>Are you sure you want to delete this record?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">Student</dt>
        <dd class="col-sm-10">@Model.Student?.FirstName @Model.Student?.LastName</dd>
        
        <dt class="col-sm-2">Book</dt>
        <dd class="col-sm-10">@(Model.Book?.Title ?? "N/A")</dd>
        
        <dt class="col-sm-2">Week Start</dt>
        <dd class="col-sm-10">@Model.WeekStartDate.ToString("yyyy-MM-dd")</dd>
        
        <dt class="col-sm-2">Reading Level</dt>
        <dd class="col-sm-10">@Model.ReadingLevel</dd>
        
        <dt class="col-sm-2">Duration</dt>
        <dd class="col-sm-10">@Model.DurationMinutes minutes</dd>
    </dl>
    
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>

